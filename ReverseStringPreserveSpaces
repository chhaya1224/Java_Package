//ReverseStringPreserveSpaces
import java.util.Scanner;

public class ReverseStringPreserveSpaces {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter a string: ");
        String input = sc.nextLine();

        char[] str = input.toCharArray();
        int left = 0, right = str.length - 1;

        while (left < right) {
            // Skip spaces from the left
            if (str[left] == ' ') {
                left++;
                continue;
            }
            // Skip spaces from the right
            if (str[right] == ' ') {
                right--;
                continue;
            }
            // Swap characters
            char temp = str[left];
            str[left] = str[right];
            str[right] = temp;

            left++;
            right--;
        }

        System.out.println("Reversed string preserving spaces: " + new String(str));
        sc.close();
    }
}
